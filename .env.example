# Free API key from https://aistudio.google.com  (no credit card required)
GEMINI_API_KEY=781585732330-cplju0qlu7po7ptb6l8c9eafp3biqc2o.apps.googleusercontent.com

# YouTube OAuth — JSON from Google Cloud Console (free)
YOUTUBE_CLIENT_SECRETS_PATH=client_secrets.json
YOUTUBE_TOKEN_PATH=token.json

# Channel settings
CHANNEL_NICHE=motivational and inspirational
NUM_SCENES=5
UPLOAD_PRIVACY=public

# Edge TTS voice — free Microsoft neural voices, no key needed
# Options: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural, en-AU-NatashaNeural
TTS_VOICE=en-US-AriaNeural

# Scheduler: 24h time
DAILY_UPLOAD_TIME=09:00

# Optional: path to a royalty-free MP3 for background music
BACKGROUND_MUSIC_PATH=
MUSIC_VOLUME=0.12
